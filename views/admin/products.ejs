<%- include('../partials/header') %>
<h2>📦 Produk Zenzo Store</h2>
<form action="/admin/product/add" method="POST" enctype="multipart/form-data" class="mb-4 p-3 bg-dark rounded">
    <input type="text" name="name" placeholder="Nama Produk" class="form-control mb-2" required>
    <input type="number" name="price" placeholder="Harga" class="form-control mb-2" required>
    <input type="number" name="stock" placeholder="Stok" class="form-control mb-2" required>
    <input type="file" name="image" class="form-control mb-2" required>
    <button class="btn btn-danger">Tambah Produk</button>
</form>
<table class="table table-dark">
    <thead><tr><th>Gambar</th><th>Nama</th><th>Harga</th><th>Stok</th><th>Aksi</th></tr></thead>
    <tbody>
    <% products.forEach(p => { %>
    <tr>
        <td><img src="/uploads/<%= p.image %>" width="50"></td>
        <td><%= p.name %></td>
        <td>Rp <%= p.price %></td>
        <td><%= p.stock %></td>
        <td>
            <a href="/admin/product/edit/<%= p.id %>" class="btn btn-warning btn-sm">Edit</a>
            <a href="/admin/product/delete/<%= p.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Yakin?')">Hapus</a>
        </td>
    </tr>
    <% }) %>
    </tbody>
</table>
<%- include('../partials/footer') %>