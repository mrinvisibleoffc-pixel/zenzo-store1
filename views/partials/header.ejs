<!DOCTYPE html>
<html>
<head>
    <title>Zenzo Store Jasa Design and Kebutuhan JB</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        @font-face {
            font-family: 'RoundedSans';
            src: url('/uploads/rounded_sans_serif_7.ttf') format('truetype');
        }
        
        body { 
            background-image: url('https://gangalink.vercel.app/i/2flpbqk1.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #ffffff !important;
            font-family: 'RoundedSans', 'Orbitron', sans-serif;
        }
        
        .navbar-brand { 
            font-weight: bold; 
            font-size: 1.5rem; 
            font-family: 'RoundedSans', 'Orbitron', sans-serif;
        }
        
        .brand-zenzo { 
            color: #ff6b35; 
        }
        
        .card { 
            background: #1a1a1a; 
            border: none; 
        }
        
        .card, .card-body, p, h1, h2, h3, h4, h5, span, div {
            color: #ffffff !important;
        }
        
        /* EFEK LED UNTUK KARTU OWNER */
        .led-card-red {
            border: 2px solid #ff0000;
            box-shadow: 0 0 10px #ff0000, 0 0 20px #ff0000, 0 0 30px #ff0000;
            animation: led-pulse-red 1.5s infinite;
            transition: all 0.3s ease;
        }
        
        @keyframes led-pulse-red {
            0% { box-shadow: 0 0 5px #ff0000, 0 0 10px #ff0000; border-color: #ff0000; }
            50% { box-shadow: 0 0 15px #ff0000, 0 0 30px #ff0000, 0 0 45px #ff0000; border-color: #ff4444; }
            100% { box-shadow: 0 0 5px #ff0000, 0 0 10px #ff0000; border-color: #ff0000; }
        }
        
        .led-card-red:hover {
            transform: scale(1.02);
            box-shadow: 0 0 20px #ff0000, 0 0 40px #ff0000, 0 0 60px #ff0000;
        }
        
        .btn-dark {
            background-color: #ff6b35;
            border: none;
            color: white;
        }
        
        .btn-dark:hover {
            background-color: #ff5500;
        }
        
        /* EFEK LED UNTUK NOMOR PEMBAYARAN */
        .led-payment {
            border: 2px solid #ff0000;
            box-shadow: 0 0 10px #ff0000, 0 0 20px #ff0000;
            animation: led-pulse-red 1.5s infinite;
            background: white;
            padding: 10px;
            border-radius: 10px;
            display: inline-block;
            color: #000000;
            font-weight: bold;
        }
    </style>
</head>
<body>
<div class="container">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <img src="https://gangalink.vercel.app/i/blob1kxt.jpg" class="rounded-circle" width="40" height="40" style="object-fit: cover; margin-right: 10px;">
                <span class="brand-zenzo">Zenzo</span> Store 👑
            </a>
            <a href="/admin/login" class="btn btn-outline-light">Admin</a>
        </div>
    </nav>
